@article{RODRIGUEZ2005125,
title = {Knowledge web-based system architecture for collaborative product development},
journal = {Computers in Industry},
volume = {56},
number = {1},
pages = {125-140},
year = {2005},
issn = {0166-3615},
doi = {https://doi.org/10.1016/j.compind.2004.07.004},
author = {Karina Rodriguez and Ahmed Al-Ashaab},
keywords = {Collaborative product development, Manufacturing model, Injection moulding process information, Knowledge web-based engineering},
abstract = {The manufacturing competitive environment has intensified in recent years. In this environment, companies do not possess all the knowledge they need but instead rely on other organizations. This results in the need of distance product development, which in turn requires information and knowledge in the place, time and format required. In response to this need the research community has come with a solution called collaborative product development (CPD) systems. This paper introduces the partial results of the ongoing research to propose a knowledge driven CPD system architecture, which will facilitate the provision of knowledge involved in product development. This paper presents the research issues and industrial requirements for such system. Furthermore, the proposed system architecture is described in detail and its implementation is presented using a case study of an injection moulded product.}
}






@article{doi:10.1177/1063293X03038367,
author = {Ahmed Al-Ashaab and \textbf{Rodriguez Echavarria, Karina} and Arturo Molina and Mauro Cardenas and Joaquin Aca and Mohammed Saeed and Hassan Abdalla},
title ={Internet-Based Collaborative Design for an Injection-moulding System},

journal = {Concurrent Engineering},
volume = {11},
number = {4},
pages = {289-299},
year = {2003},
doi = {10.1177/1063293X03038367},


    abstract = { Nowadays, the globalization of the manufacturing enterprises requires collaboration across frontiers. In order to attain effective collaboration, the information about the product life cycle must be captured and administrated in a way that supports the decision taken during the product development. In this context, the manufacturing process information needs to be shared between manufacturers. This paper introduces the SPEED (Supporting Plastic enginEEring Development) system designed to facilitate the sharing of injection-moulding information between interested parties via the Internet. Both the architecture and the functionality of the SPEED system are presented and described in this paper through a case study. The evolving issues are addressed. Finally, closing remarks and conclusions of the system are presented. }
}


