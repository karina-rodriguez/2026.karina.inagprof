@inproceedings{14f05b94a1844f5e850c87fc9d042c59,
author = {\textbf{Rodriguez Echavarria, Karina} and Morris, David and Arnold, David},
title = {Web Based Presentation of Semantically Tagged 3D Content for Public Sculptures and Monuments in the UK},
