@inproceedings{dfa9404da954440eac9bf6383aa08b17,  title     = "Exploring children's everyday journeys with user-generated AR",  abstract  = "This paper describes the design of a tool to allow children to create their own Augmented Reality (AR) content as part of creative engagement with their local environment. We are exploring AR Maps (physical maps with augmented digital content) as a way of documenting children's experiences of their local area and encouraging their understanding and appreciation of objects and sites in their communities. We have piloted the approach with children in a local primary school, with positive feedback. However, children were not able to create the AR content themselves, and their physical artwork had to be scanned by researchers. In this paper we give an overview of the design context and describe the design and implementation of a tool to allow children to create their own 3D models for the AR environment by digitising their own artwork.",  keywords  = "Augmented reality, user-generated content, digital narratives, Children, children, augmented reality",  author    = "Will Cash and Kate Howland and \textbf{{Rodriguez Echavarria}, Karina} and Myrsini Samaroudi",  year      = "2020",  month     = jun,  day       = "21",  doi       = "10.1145/3397617.3397847",    series    = "Proceedings of the 2020 ACM Interaction Design and Children Conference, IDC 2020",  publisher = "Association for Computing Machinery",  pages     = "308--313",  booktitle = "Extended Abstracts - Proceedings of the 2020 ACM Interaction Design and Children Conference, IDC 2020", }







